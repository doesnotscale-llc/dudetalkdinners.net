---
import "../index.css";
import EventsList from "../components/EventsList.astro";
import { events, formatDate, formatTime, mapsUrl } from "../data/events";
import { Icon } from "astro-icon/components";

const today = new Date().toISOString().slice(0, 10);
const nextEvent = events.find((e) => e.date >= today);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Dude Talk Dinners · Bailey</title>
    <meta
      name="description"
      content="Free food and a space to talk. All you have to do is show up."
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dudetalkdinners.net/" />
    <meta property="og:title" content="Dude Talk Dinners · Bailey" />
    <meta
      property="og:description"
      content="Free food and a space to talk. All you have to do is show up."
    />

    <meta
      property="og:image"
      content="https://dudetalkdinners.net/og-image.png"
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Dude Talk Dinners · Bailey" />
    <meta
      name="twitter:description"
      content="Free food and a space to talk. All you have to do is show up."
    />
    <meta
      name="twitter:image"
      content="https://dudetalkdinners.net/og-image.png"
    />
  </head>

  <body class="bg-dots overscroll-contain">
    <div class="h-screen">
      <div class="flex h-full w-full flex-col">
        <!-- TOP -->
        <header class="paper page-width bg-mountain pl10 mt-10 p-3 sm:p-10">
          <div class="flex justify-between gap-8">
            <h1
              class="font-anton flex flex-col gap-2 text-5xl font-normal uppercase not-italic sm:mb-5 sm:gap-3 sm:text-7xl sm:tracking-wide"
            >
              <span class="text-primary">Dude</span>
              <span class="text-secondary">Talk</span>
              <span class="text-primary">Dinners</span>
              <span
                class="font-fraunces text-accent text-4xl italic sm:text-6xl"
                >Bailey</span
              >
            </h1>

            <div
              class="font-fraunces bg-accent size-fit p-3 py-1 text-white shadow-lg shadow-black/30 sm:py-2"
            >
              <p class="text-lg">This website is for the Bailey group.</p>
              <br />
              <p class="test-base">
                Check out <a
                  class="text-blue-400 underline"
                  href="https://www.dudetalkdinners.org/"
                  target="_blank">www.dudetalkdinners.org</a
                > to find other groups near you!
              </p>
            </div>
          </div>

          <div
            class="font-fraunces text-md w-3/4 flex-col items-center justify-center space-y-3 py-5 pb-2 tracking-wide not-italic sm:pb-0 sm:text-2xl"
          >
            <p>We'll be here with free food, and a space to talk.</p>
            <p>All you have to do is show up!</p>
          </div>
        </header>

        <!-- MIDDLE -->
        <section
          class="full-width-banner flex flex-col items-center gap-2 space-y-5 p-5 sm:py-10"
        >
          <div class="flex flex-col items-center gap-4 sm:flex-row sm:gap-10">
            <h2
              class="font-fraunces bg-accent px-10 py-1 text-xl shadow-lg shadow-black/30 sm:py-2 sm:text-2xl"
            >
              Next Event
            </h2>
            {
              nextEvent && (
                <div class="flex flex-1 flex-col gap-3">
                  <>
                    <div class="flex justify-center gap-2">
                      <Icon
                        name="lucide:calendar-clock"
                        class="text-secondary h-6 w-6"
                      />
                      <p class="flex-1">
                        {formatDate(nextEvent.date)} at{" "}
                        {formatTime(nextEvent.startTime)}
                      </p>
                    </div>

                    <div class="flex justify-center gap-2">
                      <Icon
                        name="lucide:map-pin"
                        class="text-secondary h-6 w-6"
                      />
                      <a
                        class="link flex-1"
                        href={mapsUrl(nextEvent.address1, nextEvent.address2)}
                      >
                        <span class="block">{nextEvent.venueName}</span>
                        <span class="block">{nextEvent.address1}</span>
                        <span class="block">{nextEvent.address2}</span>
                      </a>
                    </div>
                  </>
                </div>
              )
            }
          </div>
        </section>

        <!-- BOTTOM -->
        <section class="page-width paper flex-1">
          <EventsList />
        </section>

        <!-- SPONSORS -->
        <section class="page-width paper p-6 pt-10 sm:p-10">
          <h2
            class="font-anton text-primary mb-6 text-2xl font-normal uppercase sm:text-3xl"
          >
            Sponsors
          </h2>
          <div class="flex flex-wrap items-center justify-center gap-8">
            <a
              href="https://www.2dadseaterytaproom.com/"
              target="_blank"
              rel="noopener"
              class="block"
            >
              <img
                src="/2-dads-banner.webp"
                alt="2 Dads Eatery & Taproom — Bailey, Colorado"
                class="block h-64 w-auto rounded-lg border border-gray-500 object-contain shadow-none transition-shadow hover:shadow-lg"
              />
            </a>
          </div>
        </section>

        <footer
          class="page-width bg-primary flex flex-col items-center justify-center gap-3 p-10 text-xs text-gray-200"
        >
          <p class="text-center font-sans text-xs uppercase sm:text-xs">
            Dude Talk Dinners · Bailey · 2026
          </p>

          <p>
            For all Dude Talk Dinners events, check out <a
              class="text-blue-400 underline"
              href="https://www.dudetalkdinners.org/"
              target="_blank">www.dudetalkdinners.org</a
            >
          </p>

          <p>
            For questions about this website for the Bailey group, contact <a
              class="text-blue-400 underline"
              href="mailto:info@doesnotscale.org"
              target="_blank">info@doesnotscale.org</a
            >
          </p>
        </footer>
      </div>
    </div>
  </body>
</html>
