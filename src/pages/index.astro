---
import "../index.css";
import EventsList from "../components/EventsList.astro";
import { events, formatDate, formatTime, mapsUrl } from "../data/events";
import { Icon } from "astro-icon/components";

const today = new Date().toISOString().slice(0, 10);
const nextEvent = events.find((e) => e.date >= today);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Dude Talk Dinners</title>
  </head>
  <body>
    <div class="bg-dots h-screen">
      <div class="flex h-full w-full flex-col">
        <!-- TOP -->
        <header class="paper page-width bg-mountain pl10 mt-10 p-3 sm:p-10">
          <h1
            class="font-anton flex flex-col gap-2 text-5xl font-normal uppercase not-italic sm:mb-5 sm:gap-3 sm:text-7xl sm:tracking-wide"
          >
            <span class="text-primary">Dude</span>
            <span class="text-secondary">Talk</span>
            <span class="text-primary">Dinners</span>
          </h1>
          <div
            class="font-fraunces text-md w-3/4 flex-col items-center justify-center space-y-3 py-5 pb-2 tracking-wide not-italic sm:pb-0 sm:text-2xl"
          >
            <p>We'll be here with free food, and a space to talk.</p>
            <p>All you have to do is show up!</p>
          </div>
        </header>

        <!-- MIDDLE -->
        <section
          class="full-width-banner flex flex-col items-center gap-2 space-y-5 p-5 sm:py-10"
        >
          <div class="flex flex-col items-center gap-4 sm:flex-row sm:gap-10">
            <h2
              class="font-fraunces bg-accent px-10 py-1 text-xl shadow-lg shadow-black/30 sm:py-2 sm:text-2xl"
            >
              Next Event
            </h2>
            {
              nextEvent && (
                <div class="flex flex-1 flex-col gap-3">
                  <>
                    <div class="flex justify-center gap-2">
                      <Icon
                        name="lucide:calendar-clock"
                        class="text-secondary h-6 w-6"
                      />
                      <p class="flex-1">
                        {formatDate(nextEvent.date)} at{" "}
                        {formatTime(nextEvent.startTime)}
                      </p>
                    </div>

                    <div class="flex justify-center gap-2">
                      <Icon
                        name="lucide:map-pin"
                        class="text-secondary mt-1 h-6 w-6"
                      />
                      <a
                        class="link flex-1"
                        href={mapsUrl(nextEvent.address1, nextEvent.address2)}
                      >
                        <span class="block">{nextEvent.venueName}</span>
                        <span class="block">{nextEvent.address1}</span>
                        <span class="block">{nextEvent.address2}</span>
                      </a>
                    </div>
                  </>
                </div>
              )
            }
          </div>
        </section>

        <!-- BOTTOM -->
        <section class="page-width paper flex-1">
          <EventsList />
        </section>

        <!-- FOOTER -->
        <footer class="page-width paper py-5">
          <p
            class="text-center font-sans text-xs text-gray-400 uppercase sm:text-sm"
          >
            Does Not Scale · 2026
          </p>
        </footer>
      </div>
    </div>
  </body>
</html>
